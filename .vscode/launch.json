{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Extension-Host",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/minify4u-test.code-workspace",
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--disable-extensions"
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "npm: compile"
    }
  ]
}
